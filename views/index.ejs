<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogs</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1 class="main">MyBlogs</h1>
    <a href="http://localhost:3000/blogs/new">Create New Blog</a>
    <hr>
    <% for(let blog of blogs)
    { %>
        <div class="blog">
            <p class="blogId">Id : <%= blog.id %></p>
            <h3 class="user">@User : <%= blog.user %></h3>
            <p class="content"><b>Content : </b> <%= blog.content %></p>
        </div>
        <a href="http://localhost:3000/blogs/<%= blog.id %>">View</a>
        <nbsp></nbsp>
        <a href="http://localhost:3000/blogs/<%= blog.id %>/update">Update</a>
        <br><br>
        <form action="http://localhost:3000/blogs/<%= blog.id %>?_method=DELETE" method="post">
             <button>Delete</button>
        </form>
       
        <hr>
    <% } %>
    
</body>
</html>